# Supabase — public client credentials (safe to expose; Row-Level Security protects data).
# Get these from the Supabase dashboard → Project Settings → API.
# Set the same two vars in Vercel → Project → Settings → Environment Variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE: the Supabase `service_role` / secret key is NEVER placed here or in the frontend.
# It is only used server-side (seeding/admin scripts) via a gitignored file.
