# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (safe to expose — shipped in the client bundle).
# Row-Level Security protects the data; the anon key is meant to be public.
# Get these from Supabase → Project Settings → API. Mirror them in Vercel.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile SITE key (public) — used by public forms (enquiries).
# (Turnstile wiring is a follow-up; the SITE key is safe in the frontend.)
VITE_TURNSTILE_SITE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY SECRETS — NEVER prefix with VITE_, never commit, never in the
# frontend bundle. Set these as Supabase secrets for the Edge Functions.
# (Names only here — no values.)
# ─────────────────────────────────────────────────────────────────────────────
# TURNSTILE_SECRET_KEY — Cloudflare Turnstile secret (verify-turnstile, follow-up)
#
# NOTE: order emails are NOT sent server-side — the admin opens a pre-filled
# Gmail draft and sends it manually. No email provider / EMAIL_API_KEY is used.
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected into
# Edge Functions automatically by Supabase. The service-role key is server-side
# ONLY — it must never appear in any VITE_ var or the frontend.
