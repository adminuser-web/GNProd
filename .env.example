# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (safe to expose — shipped in the client bundle).
# Row-Level Security protects the data; the anon key is meant to be public.
# Get these from Supabase → Project Settings → API. Mirror them in Vercel.
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile SITE key (public) — used by public forms (enquiries).
# (Turnstile wiring is a follow-up; the SITE key is safe in the frontend.)
VITE_TURNSTILE_SITE_KEY=

# "Launching Soon" preview bypass secret (public gate — NOT a data boundary).
# Set this so the bypass secret lives here instead of the world-readable
# `content` table (F-06). Share preview links as `/?preview=<this value>`.
VITE_PREVIEW_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY SECRETS — NEVER prefix with VITE_, never commit, never in the
# frontend bundle. Set these as Supabase secrets for the Edge Functions
# (`supabase secrets set NAME=value`). Names only here — no values.
# ─────────────────────────────────────────────────────────────────────────────
# Razorpay (payments):
#   RAZORPAY_KEY_ID           — rzp_live_… / rzp_test_…
#   RAZORPAY_KEY_SECRET       — Razorpay API secret
#   RAZORPAY_WEBHOOK_SECRET   — signs the payment webhook
#
# Order email (Resend, sent server-side via the send-order-email function):
#   RESEND_API_KEY            — re_…
#   EMAIL_FROM                — verified sender, e.g. "Grainood <orders@grainood.com>"
#   ADMIN_EMAILS              — comma-separated admin recipients for new-order alerts
#   EMAIL_HOOK_SECRET         — shared secret the DB webhook sends as the bearer
#
# Abuse / CORS:
#   TURNSTILE_SECRET_KEY      — Cloudflare Turnstile secret (verify-turnstile, follow-up)
#   CORS_ALLOW_ORIGIN         — set to the site origin (e.g. https://grainood.com) to
#                               scope edge-function CORS instead of "*" (F-05)
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected into
# Edge Functions automatically by Supabase. The service-role key is server-side
# ONLY — it must never appear in any VITE_ var or the frontend.
