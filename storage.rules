rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    function isImage() {
      return request.resource.size < 8 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }
    
    function isSupportDoc() {
      return request.resource.size < 8 * 1024 * 1024 && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage();
    }
    match /payments/{orderId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isImage();
    }
    match /support/{userId}/{ticketId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin()) && isSupportDoc();
    }
    match /manufacturing/{taskId}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isImage();
    }
    match /content/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isImage();
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
