{
  "entities": {
    "User": {
      "title": "User",
      "description": "Customer Profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "description": "timestamp" },
        "displayName": { "type": "string" }
      },
      "required": ["email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer Order containing checkout configuration",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending Payment", "Wood Selected", "Crafting", "Knocking In", "Shipped"] },
        "totalPrice": { "type": "number" },
        "items": { "type": "array" },
        "shippingDetails": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "status", "totalPrice", "items", "shippingDetails", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Admin privileges marker",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Admin markers"
    }
  }
}
