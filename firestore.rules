rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }
    
    match /users/{userId} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.get('role', 'customer') == 'customer';
      allow update: if isSignedIn() && (isAdmin() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'adminNotes', 'computedMetrics'])));
    }

    match /orders/{orderId} {
      allow read:   if isSignedIn() && (
                      (resource.data.userId == request.auth.uid) || 
                      isAdmin()
                    );
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'Order Placed'
                    && request.resource.data.totalPrice is number
                    && request.resource.data.totalPrice >= 0
                    && request.resource.data.createdAt != null
                    && request.resource.data.shippingDetails is map
                    && request.resource.data.shippingDetails.keys().hasAll(['name', 'email', 'phone', 'address', 'city', 'state', 'pincode'])
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && (!request.resource.data.keys().hasAny(['payment']) || request.resource.data.payment.status == 'pending');
      allow update: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /manufacturingTasks/{taskId} {
      allow read, write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if isAdmin();
    }

    match /inventoryMovements/{movId} {
      allow read, write: if isAdmin();
    }

    match /customerNotes/{noteId} {
      allow read, write: if isAdmin();
    }

    match /repairCases/{caseId} {
      allow read, write: if isAdmin();
    }

    match /pricingRules/{ruleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /discountCodes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /warranties/{warrantyId} {
      allow read, write: if isAdmin();
    }

    match /savedBuilds/{buildId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /tickets/{ticketId} {
      allow read:   if isSignedIn() && (
                      (resource.data.userId == request.auth.uid) || 
                      isAdmin()
                    );
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && request.resource.data.subject is string
                    && request.resource.data.type in ["order_query", "warranty_claim", "repair_request", "return_request", "general"]
                    && request.resource.data.messages is list
                    && request.resource.data.messages.size() > 0;
      allow update: if isAdmin() || (
                      isSignedIn() 
                      && resource.data.userId == request.auth.uid 
                      && resource.data.status != 'closed'
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['messages', 'updatedAt'])
                    );
                    
      match /notes/{noteId} {
        allow read, write: if isAdmin();
      }
    }
    
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAdmin() || (
        request.resource.data.roleTarget == 'admin' &&
        request.resource.data.type in ['new_support_request', 'new_enquiry', 'support_reply', 'enquiry_reply', 'order_created']
      ) || (
        isSignedIn() && 
        request.resource.data.roleTarget == 'customer' && 
        request.resource.data.userId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
      );
    }

    match /enquiries/{enquiryId} {
      allow create: if request.app != null
                    && request.resource.data.get('type', '') in ["product_enquiry", "custom_build", "bulk_order", "pro_consultation", "cleft_selection", "general"]
                    && (
                      (request.resource.data.get('customerName', '').size() > 0 && request.resource.data.get('customerName', '').size() <= 100) ||
                      (request.resource.data.get('name', '').size() > 0 && request.resource.data.get('name', '').size() <= 100)
                    )
                    && (
                      (request.resource.data.get('customerEmail', '').size() > 0 && request.resource.data.get('customerEmail', '').size() <= 150) || 
                      (request.resource.data.get('customerPhone', '').size() > 0 && request.resource.data.get('customerPhone', '').size() <= 30) ||
                      (request.resource.data.get('email', '').size() > 0 && request.resource.data.get('email', '').size() <= 150) ||
                      (request.resource.data.get('phone', '').size() > 0 && request.resource.data.get('phone', '').size() <= 30)
                    )
                    && request.resource.data.get('message', '').size() <= 5000
                    && request.resource.data.createdAt != null;
      allow read, update, delete: if isAdmin();
    }

    match /content/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Immutable audit trail. Admins may read and append entries (as themselves);
    // no one may ever update or delete an entry.
    match /auditLogs/{logId} {
      allow read:   if isAdmin();
      allow create: if isAdmin() && request.resource.data.actorUserId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
